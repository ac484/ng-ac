{
  "typescript.tsdk": "./node_modules/typescript/lib",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "[markdown]": {
    "editor.formatOnSave": false
  },
  "[javascript]": {
    "editor.formatOnSave": false
  },
  "[json]": {
    "editor.formatOnSave": false
  },
  "[jsonc]": {
    "editor.formatOnSave": false
  },
  "[less]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "stylelint.vscode-stylelint"
  },
  "files.watcherExclude": {
    "**/.git/*/**": true,
    "**/node_modules/*/**": true,
    "**/dist/*/**": true,
    "**/coverage/*/**": true
  },
  "files.associations": {
    "*.json": "jsonc",
    ".prettierrc": "jsonc"
  },
  "typescript.referencesCodeLens.enabled": true,
  "kiroAgent.enableTabAutocomplete": true,
  "kiroAgent.enableDebugLogs": true,
  "kiroAgent.trustedCommands": [
    "*"
  ],
  "files.exclude": {
    "**/.jpg": true,
  },
  "editor.experimental.preferTreeSitter": [
    "typescript"
  ],
  "editor.experimentalEditContextEnabled": true,
  "editor.experimental.treeSitterTelemetry": true,
  "workbench.settings.enableNaturalLanguageSearch": true,
  "explorer.autoRevealExclude": {
    "**/.cursor": true
  },
  "task.quickOpen.history": 30,
  "task.quickOpen.skip": true,
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "git.allowForcePush": true,
  "typescript.tsserver.maxTsServerMemory": 8192,
  "typescript.tsserver.nodePath": "C:\\nvm4w\\nodejs\\node.exe",
  "application.experimental.rendererProfiling": true,
  "testing.automaticallyOpenPeekViewDuringAutoRun": true,
  "typescript.tsserver.web.projectWideIntellisense.suppressSemanticErrors": false,
  "typescript.tsserver.experimental.enableProjectDiagnostics": true,
  "files.autoSave": "afterDelay"
}
